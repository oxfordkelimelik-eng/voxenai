	<string>automatic</string>
	<key>teamID</key>
	<string>359SBFFXD9</string>
	<key>uploadSymbols</key>
	<true/>
	<key>stripSwiftSymbols</key>
	<true/>
	<key>destination</key>
	<string>export</string>
</dict>
</plist>
