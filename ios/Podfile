# Flutter'ın yardımcı script'lerini yükleyen kritik satırlar:
flutter_ios_podfile_setup = File.join(File.dirname(File.expand_path(__FILE__)), 'Flutter', 'flutter_export_environment.sh')
if File.exist?(flutter_ios_podfile_setup)
  require File.expand_path(File.join(File.dirname(File.expand_path(__FILE__)), 'Flutter', 'podhelper'), __FILE__)
end

platform :ios, '15.5'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Artık bu metodu yukarıdaki podhelper sayesinde sorunsuz tanıyacak:
  flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Tüm paketlerin minimum iOS 15.5 olmasını garantiliyoruz
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
    end
  end
end