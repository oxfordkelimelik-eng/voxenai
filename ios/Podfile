platform :ios, '15.5'

# podhelper varsa yükle, yoksa çökme (Flutter config-only adımı birazdan üretecek)
podhelper_path = File.join(File.dirname(File.expand_path(__FILE__)), 'Flutter', 'podhelper')
if File.exist?("#{podhelper_path}.rb")
  require File.expand_path(podhelper_path, __FILE__)
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  if respond_to?(:flutter_install_all_ios_pods)
    flutter_install_all_ios_pods File.dirname(File.expand_path(__FILE__))
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    if respond_to?(:flutter_additional_ios_build_settings)
      flutter_additional_ios_build_settings(target)
    end
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
    end
  end
end